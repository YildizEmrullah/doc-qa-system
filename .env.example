# ─── OpenAI API Ayarları ─────────────────────────────────────────
# OpenAI API anahtarınızı buraya girin
# Yoksa sistem "Demo Modu"nda çalışır (gerçek LLM yanıtı üretilmez)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Model Ayarları ──────────────────────────────────────────────
# Embedding modeli - OpenAI embedding modellerinden biri
EMBEDDING_MODEL=text-embedding-3-small

# LLM modeli - cevap üretimi için
LLM_MODEL=gpt-4o-mini

# ─── Vektör Veritabanı ───────────────────────────────────────────
# Seçenekler: "chroma"
VECTOR_DB=chroma

# ─── RAG Ayarları ────────────────────────────────────────────────
# Her chunk'ın karakter cinsinden uzunluğu
CHUNK_SIZE=800

# Chunk'lar arası örtüşme (karakter)
CHUNK_OVERLAP=150

# Sorgu başına getirilecek maksimum chunk sayısı
TOP_K_RESULTS=5

# LLM'e gönderilecek maksimum token sayısı
MAX_TOKENS=1500

# ─── Dosya Ayarları ──────────────────────────────────────────────
# Maksimum yüklenebilir dosya boyutu (MB)
MAX_FILE_SIZE_MB=50
